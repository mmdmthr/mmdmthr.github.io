---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import LatestPosts from "../../components/LatestPosts.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import Search from "astro-pagefind/components/Search";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `Blog - ${SITE_TITLE}`,
  description: SITE_DESCRIPTION,
  url: 'https://mmdmthr.github.io/blog/',
  author: {
    '@type': 'Person',
    name: 'Hari',
    url: 'https://mmdmthr.github.io/',
  },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={`Blog - ${SITE_TITLE}`} description="All blog posts — notes on software development, engineering practices, and lessons learned from building real software." />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body
    class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen"
  >
    <Header />

    <main class="content-container py-16">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <header class="text-center mb-12">
          <h1 class="text-3xl sm:text-4xl font-bold mb-4">Blog</h1>
          <p class="text-lg text-gray-600 dark:text-gray-400">
            Notes on software development.
          </p>
        </header>

        <!-- Search -->
        <section class="max-w-3xl mx-auto">
          <Search
            id="search"
            className="pagefind-ui"
            uiOptions={{
              showImages: false,
              showSubResults: true,
            }}
          />
        </section>

        <!-- Latest Posts -->
        <section class="mt-12 max-w-3xl mx-auto">
          <LatestPosts posts={posts} />
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
